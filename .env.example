# Copy this file to .env and fill in your values for local development.
# These are only used by the agent/local_run.py script. In deployed Lambda,
# values come from CDK env vars and SSM Parameter Store.

# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# DynamoDB (optional; omit to use in-memory session cache for local dev)
SESSIONS_TABLE_NAME=

# S3 (only needed when you want to test image extraction locally)
UPLOADS_BUCKET_NAME=

# USDA FoodData Central API key for nutrition lookups.
# Get a free key at https://fdc.nal.usda.gov/api-key-signup.html
# In deployed Lambda this comes from SSM; locally set it directly here.
USDA_API_KEY=
